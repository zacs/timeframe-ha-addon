</style>

<% unless @view_object[:private_mode] %>
  <div class="three-day-columns">
    <% @view_object[:day_groups].each do |day| %>
      <div class="three-day-col<%= ' three-day-col-other' unless day[:date].to_date == @view_object[:current_time].to_date %>">
        <div class="three-day-header">
          <div style="display: flex; justify-content: space-between; align-items: center;"><%= day[:day_name] %><% if day[:clothing] %><span class="three-day-clothing-icons"><span class="three-day-clothing-icon three-day-clothing-icon-<%= day[:clothing][:shirt_icon] %>"></span><span class="three-day-clothing-icon three-day-clothing-icon-<%= day[:clothing][:icon] %>"></span></span><% end %></div>
          <div class="three-day-date"><%= day[:date].strftime("%B %-d") %></div>
        </div>

        <% if day[:weather_row]&.any? %>
          <div class="three-day-weather-row">
            <% day[:weather_row].each do |w| %>
              <span class="three-day-weather-item">
                <span class="three-day-weather-time"><%= w[:start_time] %></span>
                <i class="mdi mdi-<%= w[:icon_class] %>"></i>
                <span class="three-day-weather-temp"><%= w[:summary] %></span>
              </span>
            <% end %>
          </div>
        <% end %>

        <% show_all = @view_object.dig(:configuration, "show_all_events") == "true" %>
        <% show_icons = @view_object.dig(:configuration, "show_icons") != "false" %>
        <% daily_images = day[:show_daily] && day[:daily].any? ? (show_all ? day[:daily].select { |e| e[:timeframe_icon] || e[:kids_icon] } : day[:daily].select { |e| e[:attachment_image] || e[:kids_icon] }) : [] %>
        <% visual_periodic = show_all ? day[:periodic].select { |e| e[:timeframe_icon] || e[:kids_icon] } : day[:periodic].select { |e| e[:attachment_image] || e[:kids_icon] } %>
        <% if daily_images.any? || visual_periodic.any? %>
          <div class="three-day-events">
            <table>
              <% daily_images.each do |event| %>
                <tr>
                  <td style="white-space: nowrap; font-size: .85rem; padding: 0 .6rem 0 0; width: 1%;"></td>
                  <% if show_icons %>
                  <td class="three-day-event-icon">
                    <% if event[:kids_icon] %>
                      <i class="mdi mdi-<%= event[:kids_icon] %>"></i>
                    <% elsif event[:icon_class] %>
                      <% if event[:icon_style] %>
                        <i class="mdi mdi-<%= event[:icon_class] %>" style="<%= event[:icon_style] %>"></i>
                      <% else %>
                        <i class="mdi mdi-<%= event[:icon_class] %>"></i>
                      <% end %>
                    <% elsif event[:icon_text] %>
                      <%= event[:icon_text] %>
                    <% end %>
                  </td>
                  <% end %>
                  <td class="three-day-event-summary"><%= truncate(event[:summary], length: 30) %></td>
                </tr>
              <% end %>
              <% visual_periodic.each do |event| %>
                <tr>
                  <td style="white-space: nowrap; font-size: .85rem; padding: 0 .6rem 0 0; width: 1%;">
                    <%= event[:time_html] %>
                  </td>
                  <% if show_icons %>
                  <td class="three-day-event-icon">
                    <% if event[:kids_icon] %>
                      <i class="mdi mdi-<%= event[:kids_icon] %>"></i>
                    <% elsif event[:icon_class] %>
                      <% if event[:icon_style] %>
                        <i class="mdi mdi-<%= event[:icon_class] %>" style="<%= event[:icon_style] %>"></i>
                      <% else %>
                        <i class="mdi mdi-<%= event[:icon_class] %>"></i>
                      <% end %>
                    <% elsif event[:icon_text] %>
                      <%= event[:icon_text] %>
                    <% end %>
                  </td>
                  <% end %>
                  <td class="three-day-event-summary"><%= truncate(event[:summary], length: 30) %></td>
                </tr>
              <% end %>
            </table>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
<% end %>

<div class="timestamp" style="position: absolute; bottom: 1px; right: 1px; font-family: 'Pixelify Sans', monospace; font-size: 8px; -webkit-font-smoothing: none; z-index: 10; writing-mode: vertical-rl; text-orientation: mixed;">
  Noun Project icons. <%= @view_object[:attribution] if @view_object[:attribution].present? %> <%= @view_object[:timestamp] %>
</div>
