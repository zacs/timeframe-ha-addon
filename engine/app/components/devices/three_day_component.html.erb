<style>
  html, body { margin: 0; padding: 0; font-size: 16px; }
  .three-day-columns { display: flex; height: 100vh; gap: .35rem; padding: 1rem; box-sizing: border-box; }
  .three-day-col { flex: 1; padding: .35rem .5rem; overflow: hidden; border: 2px solid #000; border-radius: .35rem; align-self: stretch; }
  .three-day-col-other { border-color: #ccc; }
  .three-day-header { text-align: left; font-weight: 700; font-size: 1.875rem; line-height: 1.2; margin-bottom: .25rem; }
  .three-day-date { font-size: 1.5rem; font-weight: 400; line-height: 1.2; }
  .three-day-weather-row { display: flex; justify-content: space-between; margin-bottom: .25rem; }
  .three-day-weather-item { display: flex; flex-direction: column; align-items: center; flex: 1 1 0; border: 1px solid #ccc; border-radius: .25rem; padding: .2rem .1rem; margin: 0 .1rem; min-width: 0; }
  .three-day-weather-item i { font-size: 1.5rem; }
  .three-day-weather-time { font-size: .75rem; }
  .three-day-weather-temp { font-size: 1rem; }
  .three-day-events { font-size: 1.25rem; }
  .three-day-events table { width: 100%; border-collapse: collapse; }
  .three-day-events td { padding: .15rem 0; }
  .three-day-events td:first-child { text-align: left; }
  .three-day-event-icon { width: 1.35rem; text-align: center; font-size: 1.25rem; line-height: 1; font-weight: bold; }
  .three-day-events td.three-day-event-icon { padding: .15rem .25rem .15rem 0; }
  .three-day-event-summary { overflow-wrap: break-word; word-wrap: break-word; }
  .three-day-clothing-icons { display: inline-flex; align-items: center; gap: .15em; margin-left: .25em; flex-shrink: 0; }
  .three-day-clothing-icon { display: inline-block; width: 1em; height: 1em; vertical-align: middle; background-position: center; background-size: contain; background-repeat: no-repeat; }
