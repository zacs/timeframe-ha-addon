<style>
  html, body { margin: 0; padding: 0; font-size: 16px; }
  .two-day-columns { display: flex; width: 100vw; height: 100vh; gap: .5rem; padding: 1rem; box-sizing: border-box; }
  .two-day-col { flex: 1; padding: .75rem; overflow: hidden; border: 2px solid #000; border-radius: .35rem; display: flex; flex-direction: column; }
  .two-day-col-other { border-color: #e0e0e0; }
  .two-day-header { display: flex; align-items: center; justify-content: space-between; font-weight: 700; font-size: 2.5rem; line-height: 1.2; margin-bottom: .5rem; padding-bottom: .5rem; border-bottom: 1px solid #ccc; }
  .two-day-header-text { display: flex; flex-direction: column; }
  .two-day-day-name { display: flex; align-items: center; gap: .35rem; }
  .two-day-day-name i { font-size: 2.5rem; font-weight: 400; width: 3rem; text-align: center; }
  .two-day-date { font-size: 1.75rem; font-weight: 400; line-height: 1.2; }
  .two-day-header-icons { display: flex; align-items: center; gap: .5rem; }
  .two-day-header-icons .two-day-clothing-large { width: 2.5rem; height: 2.5rem; }
  .two-day-events { font-size: 2.25rem; overflow: hidden; }
  .two-day-events table { width: 100%; border-collapse: collapse; }
  .two-day-events td { padding: .25rem 0; }
  .two-day-events td:first-child { text-align: left; }
  .two-day-events td.two-day-event-icon { width: 3rem; text-align: center; font-size: 2.5rem; font-weight: bold; padding: .25rem .25rem .25rem 0; }
  .two-day-event-summary { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 0; }
  .two-day-events td.two-day-event-time { white-space: nowrap; font-size: 75%; padding: 0 .6rem 0 0; width: 1%; }
  .two-day-events-with-times { font-size: 1.5rem; }
  .two-day-events-with-times td.two-day-event-icon { width: 2rem; font-size: 1.55rem; }
  .two-day-kids-event { display: flex; flex-direction: row; align-items: center; gap: .5rem; padding: .35rem 0; }
  .two-day-kids-icon { line-height: 1; width: 3rem; text-align: center; }
  .two-day-kids-summary { font-size: 2.25rem; }
  .two-day-clothing-large { line-height: 1; }
