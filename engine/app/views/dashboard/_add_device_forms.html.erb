<div style="min-width: 300px; max-width: 300px;">
  <div class="card h-100">
    <div class="card-header">
      <h5 class="mb-0">Add Device</h5>
    </div>
    <div class="card-body">
      <%= form_tag(account_location_devices_path(account, location), method: :post, id: "add-device-form") do %>
        <div class="mb-3">
          <label class="form-label">Name</label>
          <input type="text" name="device_name" class="form-control" placeholder="e.g. Kitchen Display" required data-field="name">
        </div>
        <div class="mb-3">
          <label class="form-label">Device</label>
          <select name="device_model" class="form-select" required data-field="model">
            <option value="">Select a device...</option>
            <% Device::SUPPORTED_MODELS.each do |key, info| %>
              <option value="<%= key %>"><%= info[:name] %></option>
            <% end %>
          </select>
        </div>
        <div class="mb-3" data-pairing-code style="display: none;">
          <label class="form-label">Pairing Code</label>
          <input type="text" name="pairing_code" class="form-control" placeholder="e.g. 123456" autocomplete="off" inputmode="numeric" minlength="6" maxlength="6" pattern="[0-9]{6}" data-field="pairing">
          <% if defined?(current_user) && current_user&.is_admin? %>
            <small class="text-muted">Optional for admins</small>
          <% end %>
        </div>
        <p class="small text-muted" data-setup-note style="display: none;">On your Boox device, visit <code><%= request.base_url %>/pair</code> to get a pairing code.</p>
        <p class="small text-muted" data-trmnl-note style="display: none;">During TRMNL WiFi setup, tap Advanced &gt; Custom Server &gt; Yes and enter <code><%= request.base_url %></code> as the API server URL. The device will register and display a pairing code. <a href="https://help.trmnl.com/en/articles/12263392-connect-your-device-to-terminus-byos" target="_blank">Learn more</a></p>
        <p class="small text-muted" data-reterminal-note style="display: none;">In your reTerminal E10-3 SenseCraft HMI settings, set the API server URL to <code><%= request.base_url %></code>. The device will register and display a pairing code.</p>
        <p class="small text-muted" data-trmnl-x-note style="display: none;">During TRMNL WiFi setup, tap Advanced &gt; Custom Server &gt; Yes and enter <code><%= request.base_url %></code> as the API server URL. The device will register and display a pairing code. <a href="https://help.trmnl.com/en/articles/12263392-connect-your-device-to-terminus-byos" target="_blank">Learn more</a></p>
        <p class="small text-muted" data-reterminal-e1001-note style="display: none;">During TRMNL WiFi setup, tap Advanced &gt; Custom Server &gt; Yes and enter <code><%= request.base_url %></code> as the API server URL. The device will register and display a pairing code.</p>
        <p class="small text-muted" data-display-1080p-note style="display: none;">On your display device, visit <code><%= request.base_url %>/pair</code> to get a pairing code.</p>
        <%= submit_tag "Add Device", class: "btn btn-primary w-100", disabled: true, id: "add-device-btn" %>
      <% end %>
    </div>
  </div>
</div>
<script>
(function() {
  var form = document.getElementById('add-device-form');
  var nameInput = form.querySelector('[data-field="name"]');
  var modelSelect = form.querySelector('[data-field="model"]');
  var pairingInput = form.querySelector('[data-field="pairing"]');
  var pairingWrap = form.querySelector('[data-pairing-code]');
  var setupNote = form.querySelector('[data-setup-note]');
  var trmnlNote = form.querySelector('[data-trmnl-note]');
  var reterminalNote = form.querySelector('[data-reterminal-note]');
  var trmnlXNote = form.querySelector('[data-trmnl-x-note]');
  var reterminalE1001Note = form.querySelector('[data-reterminal-e1001-note]');
  var display1080pNote = form.querySelector('[data-display-1080p-note]');
  var btn = document.getElementById('add-device-btn');

  function needsPairing() {
    return modelSelect.value !== '' && modelSelect.value !== 'visionect_13';
  }

  <% admin = defined?(current_user) && current_user&.is_admin? %>
  var isAdmin = <%= admin ? "true" : "false" %>;

  function updateState() {
    var showPairing = needsPairing();
    pairingWrap.style.display = showPairing ? '' : 'none';
    pairingInput.required = showPairing && !isAdmin;
    setupNote.style.display = (modelSelect.value === 'boox_mira_pro' || modelSelect.value === 'boox_mira') ? '' : 'none';
    trmnlNote.style.display = modelSelect.value === 'trmnl_og' ? '' : 'none';
    reterminalNote.style.display = modelSelect.value === 'reterminal_e1003' ? '' : 'none';
    trmnlXNote.style.display = modelSelect.value === 'trmnl_x' ? '' : 'none';
    reterminalE1001Note.style.display = modelSelect.value === 'reterminal_e1001' ? '' : 'none';
    display1080pNote.style.display = modelSelect.value === 'display_1080p' ? '' : 'none';

    var valid = nameInput.value.trim() !== '' && modelSelect.value !== '';
    if (showPairing && !isAdmin) valid = valid && /^[0-9]{6}$/.test(pairingInput.value);
    if (showPairing && isAdmin && pairingInput.value !== '') valid = valid && /^[0-9]{6}$/.test(pairingInput.value);
    btn.disabled = !valid;
  }

  nameInput.addEventListener('input', updateState);
  modelSelect.addEventListener('change', updateState);
  pairingInput.addEventListener('input', updateState);
})();
</script>
