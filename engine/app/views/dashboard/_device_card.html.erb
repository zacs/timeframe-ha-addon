<div style="min-width: 300px;">
  <div class="card h-100">
    <div class="card-header d-flex justify-content-between align-items-center">
      <h5 class="mb-0"><%= device.name %></h5>
      <% if device.battery_level.present? %>
        <%
          bl = device.battery_level.to_i
          battery_icon = if bl > 90 then "battery"
            elsif bl > 70 then "battery-80"
            elsif bl > 50 then "battery-60"
            elsif bl > 30 then "battery-40"
            elsif bl > 10 then "battery-20"
            elsif bl > 0  then "battery-10"
            else "battery-outline"
            end
          battery_color = if bl <= 5 then "text-danger"
            elsif bl <= 20 then "text-warning"
            else "text-body-tertiary"
            end
        %>
        <span class="<%= battery_color %>" style="font-size: 0.85rem; white-space: nowrap;">
          <i class="mdi mdi-<%= battery_icon %>"></i> <%= bl %>%
        </span>
      <% end %>
    </div>
    <div class="card-body p-0">
      <% aspect_ratio = (device.display_height.to_f / device.display_width * 100).round(2) %>
      <div style="position: relative; width: 100%; padding-bottom: <%= aspect_ratio %>%; overflow: hidden; background: white;">
        <% if device.cached_image.present? %>
          <% if device.reterminal_e1003? %>
            <img src="data:image/png;base64,<%= device.cached_image %>" style="position: absolute; top: 50%; left: 50%; width: <%= aspect_ratio %>%; transform: translate(-50%, -50%) rotate(-90deg);">
          <% elsif device.portrait? %>
            <img src="data:image/png;base64,<%= device.cached_image %>" style="position: absolute; top: 50%; left: 50%; width: <%= aspect_ratio %>%; transform: translate(-50%, -50%) rotate(-90deg);">
          <% else %>
            <img src="data:image/png;base64,<%= device.cached_image %>" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: contain;">
          <% end %>
        <% elsif device.screenshotted? %>
          <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;">
            <span class="text-muted">Could not render display</span>
          </div>
        <% else %>
          <% preview_url = account_location_device_path(account, device.location, device) %>
          <iframe
            src="<%= preview_url %>"
            width="<%= device.display_width %>"
            height="<%= device.display_height %>"
            scrolling="no"
            style="border: none; position: absolute; top: 0; left: 0; width: <%= device.display_width %>px; height: <%= device.display_height %>px; transform-origin: top left;"
            onload="this.style.transform='scale('+this.parentElement.offsetWidth/<%= device.display_width %>+')';"
          ></iframe>
        <% end %>
      </div>
    </div>
    <% if device.disconnected? %>
      <div class="card-body py-2 border-top bg-warning-subtle">
        <div class="d-flex align-items-center justify-content-between">
          <small class="text-warning-emphasis"><i class="mdi mdi-alert-circle"></i> Disconnected</small>
          <button type="button" class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#repair-device-<%= device.id %>">Reconnect</button>
        </div>
      </div>
    <% end %>
    <div class="card-footer d-flex justify-content-between align-items-center">
      <% updated_at = device.cached_image_at || device.last_connection_at || device.updated_at %>
      <% updated_label = if updated_at > 1.minute.ago
        "<1m"
      else
        time_ago_in_words(updated_at)
      end %>
      <span class="text-body-tertiary" style="font-size: 0.75rem;">Updated <%= updated_label %> ago</span>
      <a href="<%= settings_account_location_device_path(account, location, device) %>" class="btn btn-outline-secondary btn-sm"><i class="mdi mdi-cog me-1"></i>Settings</a>
    </div>

    <% if device.pairing_code_device? %>
      <div class="modal fade" id="repair-device-<%= device.id %>" tabindex="-1" aria-labelledby="repair-device-label-<%= device.id %>" aria-hidden="true">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="repair-device-label-<%= device.id %>">Reconnect "<%= device.name %>"</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <%= form_with url: repair_account_location_device_path(account, location, device), method: :post do %>
              <div class="modal-body">
                <% if device.reterminal_e1003? %>
                  <p>On your reTerminal, reconnect to the API server at <code><%= request.base_url %></code> to get a new pairing code.</p>
                <% elsif device.trmnl? || device.reterminal_e1001? %>
                  <p>On your device, reconnect to the API server at <code><%= request.base_url %></code> to get a new pairing code.</p>
                <% else %>
                  <p>On your device, visit <code><%= request.base_url %>/pair</code> to get a new pairing code.</p>
                <% end %>
                <label class="form-label">Pairing Code</label>
                <input type="text" name="pairing_code" class="form-control" placeholder="e.g. 123456" autocomplete="off" inputmode="numeric" minlength="6" maxlength="6" pattern="[0-9]{6}" data-repair-input="<%= device.id %>">
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <%= submit_tag "Reconnect Device", class: "btn btn-primary", disabled: true, id: "repair-btn-#{device.id}" %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
      <script>
        (function() {
          var input = document.querySelector('[data-repair-input="<%= device.id %>"]');
          var btn = document.getElementById('repair-btn-<%= device.id %>');
          input.addEventListener('input', function() {
            btn.disabled = !/^[0-9]{6}$/.test(input.value);
          });
        })();
      </script>
    <% end %>
  </div>
</div>
