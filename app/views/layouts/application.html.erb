<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Timeframe</title>
    <link rel="icon" href="/favicon.ico" sizes="any">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="256x256" href="/sun-angle-outline.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
    <link rel="manifest" href="/site.webmanifest">
    <meta name="theme-color" content="#f1f3f5">
    <%= stylesheet_link_tag "application" %>
    <link rel="stylesheet" href="/css/mdi/materialdesignicons.css">
  </head>
  <body>
    <nav class="navbar navbar-expand-md app-header mb-3">
      <div class="container">
        <a class="navbar-brand app-logo" href="/">
          <i class="mdi mdi-sun-angle-outline app-logo__icon" aria-hidden="true"></i>
          <span>timeframe</span>
        </a>
        <ul class="navbar-nav ms-auto">
          <li class="nav-item">
            <a class="nav-link" href="/status">Status</a>
          </li>
        </ul>
      </div>
    </nav>

    <div class="container">
      <% flash.each do |key, value| %>
        <div class="alert alert-<%= key == 'notice' ? 'success' : 'danger' %> alert-dismissible fade show" role="alert">
          <%= value %>
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      <% end %>

      <%= yield %>
    </div>

    <footer class="container mt-4 mb-3 text-center text-muted small">
      &copy; 2016-<%= Time.current.year %> Joel Hawksley &middot;
      <a href="https://github.com/timeframe/timeframe" class="text-muted" target="_blank">GitHub</a>
    </footer>

    <%= javascript_include_tag "popper.min" %>
    <%= javascript_include_tag "bootstrap.min" %>
  </body>
</html>
